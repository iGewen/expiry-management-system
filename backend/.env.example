# 数据库连接
DATABASE_URL="mysql://expiry_user:your_password@localhost:3306/expiry_management"

# 服务器配置
NODE_ENV=development
PORT=3000

# JWT 配置（生产环境必须修改！）
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 阿里云短信配置（可选，不配置则无法发送短信验证码）
# 阿里云 AccessKey：https://ram.console.aliyun.com/manage/ak
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
# 短信签名：需要在阿里云控制台申请
ALIYUN_SMS_SIGN_NAME=您的公司或应用名称
# 短信模板Code：需要在阿里云控制台申请，模板内容如：您的验证码为${code}，5分钟内有效
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789
# 短信服务区域（一般不需要修改）
ALIYUN_SMS_REGION=cn-hangzhou

# 日志配置
LOG_LEVEL=info
LOG_RETENTION_DAYS=180

# 文件上传配置
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=./uploads

# CORS 配置（多个域名用逗号分隔）
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Redis 配置（可选，用于存储登录失败计数和验证码，不配置则使用内存）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
# REDIS_DB=0
