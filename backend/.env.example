# ========================================
# 商品保质期管理系统 - 环境变量配置说明
# ========================================
# 
# 📌 必填项说明：
#    - 标注【必填】的变量必须设置，否则应用无法启动
#    - 标注【强烈推荐】的变量建议设置，影响系统功能
#    - 标注【可选】的变量可根据需要配置
#
# 🔒 安全提示：
#    - 所有密钥类变量请使用强随机字符串（至少32位）
#    - 生产环境不要使用默认值或示例值
#    - 不要将 .env 文件提交到代码仓库

# ========================================
# 基础配置
# ========================================

# 【必填】数据库连接字符串
# 格式：mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql://expiry_user:your_secure_password@localhost:3306/expiry_management

# 【必填】服务器运行环境
# 可选值：development | production | test
NODE_ENV=production

# 【可选】服务器端口
# 默认值：3000
PORT=3000

# ========================================
# 安全配置 - JWT 认证
# ========================================

# 【必填】JWT 密钥
# 安全要求：
#   - 至少 32 个字符
#   - 使用强随机字符串
#   - 生产环境必须修改，不能用默认值
# 生成方法：openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long-change-this

# 【可选】JWT Token 有效期
# 默认值：7d (7天)
# 格式：数字 + 单位（s=秒, m=分, h=小时, d=天）
JWT_EXPIRES_IN=7d

# 【可选】JWT 刷新 Token 有效期
# 默认值：30d (30天)
JWT_REFRESH_EXPIRES_IN=30d

# ========================================
# CORS 跨域配置
# ========================================

# 【必填】允许的前端域名
# 重要：
#   - 不能使用通配符 *（安全风险）
#   - 多个域名用逗号分隔
#   - 必须包含协议（http:// 或 https://）
# 示例：http://localhost:5173,https://example.com
CORS_ORIGIN=http://localhost:5173

# ========================================
# Redis 配置（可选）
# ========================================
# 用途：存储登录失败计数、验证码、缓存
# 如果不配置，系统会自动降级使用内存存储

# 【可选】Redis 连接地址
# 格式：redis://:密码@主机:端口/数据库编号
# REDIS_URL=redis://:your_redis_password@localhost:6379/0

# 【可选】Redis 主机地址
# REDIS_HOST=localhost

# 【可选】Redis 端口
# REDIS_PORT=6379

# 【可选】Redis 密码
# REDIS_PASSWORD=your_redis_password

# 【可选】Redis 数据库编号
# REDIS_DB=0

# ========================================
# 阿里云短信配置（可选）
# ========================================
# 用途：发送短信验证码和过期提醒
# 如果不配置，短信相关功能将禁用

# 【可选】阿里云 AccessKey ID
# 获取地址：https://ram.console.aliyun.com/manage/ak
# ALIYUN_ACCESS_KEY_ID=your_access_key_id

# 【可选】阿里云 AccessKey Secret
# ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret

# 【可选】短信签名名称
# 需要在阿里云控制台申请
# ALIYUN_SMS_SIGN_NAME=您的公司名称

# 【可选】注册验证码模板 Code
# 模板示例：您的验证码为${code}，5分钟内有效
# ALIYUN_SMS_TEMPLATE_CODE_REGISTER=SMS_123456789

# 【可选】重置密码验证码模板 Code
# 模板示例：您的验证码为${code}，5分钟内有效
# ALIYUN_SMS_TEMPLATE_CODE_RESET=SMS_987654321

# 【可选】过期提醒模板 Code
# 模板示例：您好！您有${other_number2}件商品即将过期，请及时处理
# ALIYUN_SMS_TEMPLATE_CODE_REMINDER=SMS_456789123

# 【可选】短信服务区域
# 默认值：cn-hangzhou
# ALIYUN_SMS_REGION=cn-hangzhou

# ========================================
# 飞书登录配置（可选）
# ========================================
# 用途：支持飞书账号登录

# 【可选】飞书应用 ID
# 获取地址：https://open.feishu.cn/app
# FEISHU_APP_ID=cli_xxxxxxxxx

# 【可选】飞书应用 Secret
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# 【可选】飞书登录回调地址
# 必须与飞书应用配置的回调地址一致
# 格式：https://your-domain/api/auth/feishu/callback
# FEISHU_REDIRECT_URI=https://your-domain/api/auth/feishu/callback

# ========================================
# 日志配置
# ========================================

# 【可选】日志级别
# 可选值：error | warn | info | debug
# 默认值：info
LOG_LEVEL=info

# 【可选】日志保留天数
# 默认值：180 天
LOG_RETENTION_DAYS=180

# ========================================
# 文件上传配置
# ========================================

# 【可选】文件上传最大大小（字节）
# 默认值：10485760 (10MB)
UPLOAD_MAX_SIZE=10485760

# 【可选】文件上传路径
# 默认值：./uploads
UPLOAD_PATH=./uploads

# ========================================
# Docker 部署专用变量
# ========================================
# 以下变量仅在 docker-compose.yml 中使用

# 【Docker必填】MySQL root 密码
# MYSQL_ROOT_PASSWORD=your_mysql_root_password

# 【Docker必填】MySQL 应用密码
# MYSQL_PASSWORD=your_mysql_password

# 【Docker必填】Redis 密码
# REDIS_PASSWORD=your_redis_password

# 【Docker必填】JWT 刷新密钥
# JWT_REFRESH_SECRET=your-refresh-secret-key

# ========================================
# 开发调试配置（仅开发环境使用）
# ========================================

# 【可选】跳过数据库迁移
# 用于手动管理迁移的场景
# SKIP_MIGRATION=false

# ========================================
# 📝 配置示例
# ========================================
#
# 最小配置（仅必填项）：
# DATABASE_URL=mysql://expiry_user:password@localhost:3306/expiry_management
# NODE_ENV=production
# JWT_SECRET=<使用 openssl rand -base64 32 生成>
# CORS_ORIGIN=http://localhost:5173
#
# 生产环境推荐配置：
# - 配置 Redis（提升性能）
# - 配置短信服务（启用验证码和提醒功能）
# - 配置飞书登录（可选）
# - 使用 HTTPS（CORS_ORIGIN 配置 https:// 域名）

# ========================================
# ⚠️  安全检查清单
# ========================================
# 启动前请确认：
# □ JWT_SECRET 已修改为强随机字符串（至少32位）
# □ CORS_ORIGIN 已配置具体域名，未使用 *
# □ 数据库密码已修改，未使用默认密码
# □ 生产环境 NODE_ENV 设置为 production
# □ .env 文件未提交到代码仓库（已在 .gitignore 中）
