// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum ImportStatus {
  SUCCESS
  FAILED
  PARTIAL
}

enum ProductStatus {
  NORMAL
  WARNING
  EXPIRED
}

model User {
  id            Int             @id @default(autoincrement())
  username      String          @unique @db.VarChar(50)
  password      String          @db.VarChar(255)
  phone         String?         @unique @db.VarChar(20)
  email         String?         @unique @db.VarChar(100)
  avatar        String?         @db.VarChar(500)
  feishuOpenId String?         @unique @db.VarChar(100) // 飞书 open_id
  role          Role            @default(USER)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  lastLoginAt   DateTime?
  lastLoginIp   String?         @db.VarChar(50)
  products      Product[]
  logs          Log[]
  importHistory ImportHistory[]
  categories    Category[]      // 用户自定义分类
  reminderSetting ReminderSetting? // 提醒设置

  @@index([username])
  @@index([phone])
  @@index([feishuOpenId])
  @@map("users")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(50)
  color     String    @default("#409EFF") // 分类颜色
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, name]) // 同一用户分类名不能重复
  @@index([userId])
  @@map("categories")
}

model Product {
  id             Int           @id @default(autoincrement())
  name           String        @db.VarChar(100)
  barcode        String?       @db.VarChar(50) // 商品条码
  productionDate DateTime
  shelfLife      Int           // 保质期天数
  expiryDate     DateTime      // 过期日期（冗余字段，用于高效查询）
  reminderDays   Int           @default(3) // 提醒提前天数
  status         ProductStatus @default(NORMAL) // 状态冗余字段
  userId         Int
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId     Int?          // 分类ID
  category       Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  isDeleted      Boolean       @default(false)

  @@index([userId])
  @@index([categoryId])
  @@index([productionDate])
  @@index([expiryDate])
  @@index([status])
  @@index([isDeleted])
  @@index([userId, status, isDeleted]) // 复合索引优化查询
  @@map("products")
}

model ReminderSetting {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique // 每个用户一个设置
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled         Boolean  @default(true) // 是否启用提醒
  reminderTime    String   @default("09:00") // 提醒时间，如 "09:00"
  phones          String   @default("[]") // 提醒手机号列表，JSON数组格式，如 ["13800138000", "13900139000"]
  remindBySms     Boolean  @default(true) // 短信提醒
  remindByEmail   Boolean  @default(false) // 邮件提醒
  // 飞书机器人配置
  feishuEnabled   Boolean  @default(false) // 是否启用飞书提醒
  feishuWebhook   String?  @db.VarChar(500) // 飞书群机器人 webhook 地址
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("reminder_settings")
}

model ReminderLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  productId   Int
  productName String   @db.VarChar(100)
  expiryDate  DateTime
  sentAt      DateTime @default(now())
  channel     String   @default("sms") // sms/email
  status      String   @default("success") // success/failed
  errorMsg    String?  @db.Text

  @@index([userId])
  @@index([sentAt])
  @@map("reminder_logs")
}

model Log {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   @db.VarChar(50)
  details   String?  @db.Text
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@index([userId, action, createdAt]) // 复合索引
  @@map("logs")
}

model ImportHistory {
  id           Int          @id @default(autoincrement())
  userId       Int
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename     String       @db.VarChar(255)
  totalCount   Int          @default(0)
  successCount Int          @default(0)
  failCount    Int          @default(0)
  status       ImportStatus @default(SUCCESS)
  errors       String?      @db.Text // JSON格式存储错误信息
  createdAt    DateTime     @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("import_history")
}
