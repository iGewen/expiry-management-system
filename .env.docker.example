# ========================================
# Docker 部署 - 环境变量配置
# ========================================
#
# 📌 说明：
#    - 此文件用于 Docker Compose 部署
#    - 复制此文件为 .env 并修改配置
#    - 所有【必填】项必须配置，否则容器无法启动
#
# 🔒 安全提示：
#    - 所有密码请使用强随机字符串
#    - 不要使用示例值或默认密码
#    - 不要将 .env 文件提交到代码仓库

# ========================================
# 数据库配置 - MySQL
# ========================================

# 【必填】MySQL root 用户密码
# 建议：使用强随机密码（至少16位）
# 生成方法：openssl rand -base64 16
MYSQL_ROOT_PASSWORD=your_secure_root_password_change_this

# 【必填】MySQL 应用用户密码
# expiry_user 用户使用此密码
MYSQL_PASSWORD=your_secure_mysql_password_change_this

# ========================================
# 缓存配置 - Redis
# ========================================

# 【必填】Redis 访问密码
# 建议：使用强随机密码
REDIS_PASSWORD=your_secure_redis_password_change_this

# ========================================
# JWT 认证配置
# ========================================

# 【必填】JWT 主密钥
# 安全要求：
#   - 至少 32 个字符
#   - 使用强随机字符串
#   - 生产环境必须修改
# 生成方法：openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-at-least-32-characters-change-this

# 【必填】JWT 刷新密钥
# 用于生成刷新 Token
# 生成方法：openssl rand -base64 32
JWT_REFRESH_SECRET=your-refresh-secret-key-at-least-32-characters-change-this

# ========================================
# CORS 跨域配置
# ========================================

# 【必填】前端访问域名
# 重要：
#   - 不能使用 * (安全风险)
#   - 必须包含协议 (http:// 或 https://)
#   - 多个域名用逗号分隔
# 示例：https://example.com,https://www.example.com
CORS_ORIGIN=http://your-domain.com

# ========================================
# 飞书登录配置（可选）
# ========================================
# 用途：支持飞书账号登录
# 如果不需要飞书登录，可以不配置

# 【可选】飞书应用 ID
# FEISHU_APP_ID=cli_xxxxxxxxx

# 【可选】飞书应用 Secret
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# 【可选】飞书登录回调地址
# 必须与飞书应用配置一致
# 格式：https://your-domain/api/auth/feishu/callback
# FEISHU_REDIRECT_URI=https://your-domain.com/api/auth/feishu/callback

# ========================================
# 阿里云短信配置（可选）
# ========================================
# 用途：短信验证码和过期提醒
# 如果不需要短信功能，可以不配置

# 【可选】阿里云 AccessKey ID
# ALIYUN_ACCESS_KEY_ID=your_access_key_id

# 【可选】阿里云 AccessKey Secret
# ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret

# 【可选】短信签名
# ALIYUN_SMS_SIGN_NAME=您的公司名称

# 【可选】短信模板 Code
# ALIYUN_SMS_TEMPLATE_CODE_REGISTER=SMS_xxx
# ALIYUN_SMS_TEMPLATE_CODE_RESET=SMS_xxx
# ALIYUN_SMS_TEMPLATE_CODE_REMINDER=SMS_xxx

# ========================================
# 📝 快速开始
# ========================================
#
# 1. 复制配置文件：
#    cp .env.docker.example .env
#
# 2. 修改必填项：
#    - MYSQL_ROOT_PASSWORD
#    - MYSQL_PASSWORD
#    - REDIS_PASSWORD
#    - JWT_SECRET
#    - JWT_REFRESH_SECRET
#    - CORS_ORIGIN
#
# 3. 启动服务：
#    docker-compose up -d
#
# 4. 访问应用：
#    前端：http://your-domain
#    后端：http://your-domain:3000
#    健康检查：http://your-domain:3000/health

# ========================================
# ⚠️  安全检查清单
# ========================================
# 启动前请确认：
# □ JWT_SECRET 已修改为强随机字符串（至少32位）
# □ JWT_REFRESH_SECRET 已修改为强随机字符串
# □ MYSQL_ROOT_PASSWORD 已修改为强密码
# □ MYSQL_PASSWORD 已修改为强密码
# □ REDIS_PASSWORD 已修改为强密码
# □ CORS_ORIGIN 已配置具体域名，未使用 *
# □ .env 文件未提交到代码仓库
