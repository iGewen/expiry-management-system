# Docker 环境变量配置
# 复制此文件为 .env 并修改配置

# MySQL 配置
MYSQL_ROOT_PASSWORD=root123456
MYSQL_PASSWORD=expiry123456

# Redis 配置
REDIS_PASSWORD=redis123456

# JWT 配置（生产环境请使用强密钥）
JWT_SECRET=your-super-secret-jwt-key-change-in-production-at-least-32-chars

# CORS 配置（前端域名）
CORS_ORIGIN=http://localhost

# 阿里云短信（可选）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE_REGISTER=
ALIYUN_SMS_TEMPLATE_CODE_RESET=
ALIYUN_SMS_TEMPLATE_CODE_REMINDER=

# 飞书登录配置（可选）
# FEISHU_APP_ID=cli_xxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxx
# FEISHU_REDIRECT_URI=http://your-domain.com/api/auth/feishu/callback
