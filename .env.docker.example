# Database
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_PASSWORD=your_mysql_password

# Redis
REDIS_PASSWORD=your_redis_password

# JWT
JWT_SECRET=your-jwt-secret-key
JWT_REFRESH_SECRET=your-refresh-secret-key

# Feishu
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_REDIRECT_URI=http://your-domain/api/auth/feishu/callback

# Aliyun SMS
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=your_sign_name
ALIYUN_SMS_TEMPLATE_CODE_REGISTER=SMS_xxx
ALIYUN_SMS_TEMPLATE_CODE_RESET=SMS_xxx
ALIYUN_SMS_TEMPLATE_CODE_REMINDER=SMS_xxx

# CORS - 前端URL，用于飞书登录重定向
CORS_ORIGIN=http://your-domain
